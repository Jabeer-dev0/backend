# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/anikura

# Frontend URL(s) for CORS — comma-separated
FRONTEND_URL=http://localhost:5173,https://YOUR_USERNAME.github.io

# Video files — local dev uses ./data/videos; Vercel uses /tmp automatically
VIDEO_STORAGE_PATH=./data/videos

# JWT
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
